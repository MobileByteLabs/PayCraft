# PayCraft Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# .env is gitignored — never commit real secrets.
# All keys are prefixed PAYCRAFT_ so Claude never confuses them with app keys.
#
# DUAL MODE: This file holds BOTH test and production keys.
# Set PAYCRAFT_MODE=test during development, PAYCRAFT_MODE=live before launch.
# ─────────────────────────────────────────────────────────────────────────────

# ── Mode Switch ───────────────────────────────────────────────────────────────
# Controls which set of Stripe keys / links / secrets the adopt commands use.
# Values: test | live
# Start with "test" — switch to "live" after full E2E verification in test mode.
PAYCRAFT_MODE=test

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL (e.g. https://abcdefghij.supabase.co)
# Find it: https://supabase.com/dashboard/project/<ref>/settings/api
PAYCRAFT_SUPABASE_URL=

# Project ref slug (the part after /project/ in your dashboard URL)
# Example: abcdefghij
PAYCRAFT_SUPABASE_PROJECT_REF=

# Anon/public key — safe to embed in client apps
# Find it: https://supabase.com/dashboard/project/<ref>/settings/api → Project API keys → anon
PAYCRAFT_SUPABASE_ANON_KEY=

# Service role key — NEVER expose in client apps; used only by Claude for setup
# Find it: https://supabase.com/dashboard/project/<ref>/settings/api → Project API keys → service_role
PAYCRAFT_SUPABASE_SERVICE_ROLE_KEY=

# Personal access token — used by Supabase CLI / Management API for migrations + deploy
# Generate at: https://supabase.com/dashboard/account/tokens
PAYCRAFT_SUPABASE_ACCESS_TOKEN=

# ── Stripe TEST mode ─────────────────────────────────────────────────────────
# Use these during development — no real charges.
# Get test keys at: https://dashboard.stripe.com/test/apikeys
# Toggle "Test mode" ON in top-right of Stripe Dashboard first.

# Secret key (starts with sk_test_) — used only by Claude to create products via API
PAYCRAFT_STRIPE_TEST_SECRET_KEY=

# Publishable key (starts with pk_test_) — optional, for client-side display
PAYCRAFT_STRIPE_TEST_PUBLISHABLE_KEY=

# Webhook signing secret — set AFTER creating test webhook in Stripe Dashboard
# Find it: https://dashboard.stripe.com/test/webhooks → your endpoint → Signing secret
PAYCRAFT_STRIPE_TEST_WEBHOOK_SECRET=

# Test payment links — filled automatically by /paycraft-adopt-stripe (test phase)
# These point to buy.stripe.com/test/... and charge no real money
PAYCRAFT_STRIPE_TEST_LINK_MONTHLY=
PAYCRAFT_STRIPE_TEST_LINK_QUARTERLY=
PAYCRAFT_STRIPE_TEST_LINK_YEARLY=

# Test customer portal URL — enable at: https://dashboard.stripe.com/test/settings/billing/portal
PAYCRAFT_STRIPE_TEST_PORTAL_URL=

# Test product + price IDs — auto-filled by /paycraft-adopt-stripe, safe to delete after setup
PAYCRAFT_STRIPE_TEST_PRODUCT_ID=
PAYCRAFT_STRIPE_TEST_PRICE_MONTHLY=
PAYCRAFT_STRIPE_TEST_PRICE_QUARTERLY=
PAYCRAFT_STRIPE_TEST_PRICE_YEARLY=

# ── Stripe LIVE (production) mode ────────────────────────────────────────────
# Use these when you're ready to accept real payments.
# Get live keys at: https://dashboard.stripe.com/apikeys (Test mode toggle OFF)
# ⚠️  NEVER put live keys in client apps or git. Only here in .env (gitignored).

# Secret key (starts with sk_live_) — used only by Claude to create live resources
PAYCRAFT_STRIPE_LIVE_SECRET_KEY=

# Publishable key (starts with pk_live_)
PAYCRAFT_STRIPE_LIVE_PUBLISHABLE_KEY=

# Webhook signing secret for live endpoint (starts with whsec_)
# Find it: https://dashboard.stripe.com/webhooks → your live endpoint → Signing secret
PAYCRAFT_STRIPE_LIVE_WEBHOOK_SECRET=

# Live payment links — filled by /paycraft-adopt-stripe (live phase)
# These charge real money — do NOT use until E2E test mode verification passes
PAYCRAFT_STRIPE_LIVE_LINK_MONTHLY=
PAYCRAFT_STRIPE_LIVE_LINK_QUARTERLY=
PAYCRAFT_STRIPE_LIVE_LINK_YEARLY=

# Live customer portal URL — enable at: https://dashboard.stripe.com/settings/billing/portal
PAYCRAFT_STRIPE_LIVE_PORTAL_URL=

# Live product + price IDs — auto-filled by /paycraft-adopt-stripe (live phase)
PAYCRAFT_STRIPE_LIVE_PRODUCT_ID=
PAYCRAFT_STRIPE_LIVE_PRICE_MONTHLY=
PAYCRAFT_STRIPE_LIVE_PRICE_QUARTERLY=
PAYCRAFT_STRIPE_LIVE_PRICE_YEARLY=

# ── Razorpay (if using RazorpayProvider) ─────────────────────────────────────
# Key ID — starts with rzp_test_ or rzp_live_
# Find it: https://dashboard.razorpay.com/app/keys
PAYCRAFT_RAZORPAY_KEY_ID=

# Key secret — treat like a password, never expose in client apps
PAYCRAFT_RAZORPAY_KEY_SECRET=

# Webhook secret — set when creating webhook in Razorpay Dashboard
# Find it: https://dashboard.razorpay.com/app/webhooks
PAYCRAFT_RAZORPAY_WEBHOOK_SECRET=

# Payment links — filled automatically by /setup-razorpay or manually
PAYCRAFT_RAZORPAY_LINK_MONTHLY=
PAYCRAFT_RAZORPAY_LINK_QUARTERLY=
PAYCRAFT_RAZORPAY_LINK_YEARLY=

# ── Razorpay Plans (auto-filled by /paycraft-adopt-razorpay) ─────────────────
# Plan IDs created by /paycraft-adopt — safe to delete after setup
PAYCRAFT_RAZORPAY_PLAN_MONTHLY=
PAYCRAFT_RAZORPAY_PLAN_QUARTERLY=
PAYCRAFT_RAZORPAY_PLAN_YEARLY=

# ── Maven Central (used by scripts/release.sh for local publishing) ───────────
# Username from https://central.sonatype.com/account
PAYCRAFT_MAVEN_CENTRAL_USERNAME=

# Password / token from Sonatype Central
PAYCRAFT_MAVEN_CENTRAL_PASSWORD=

# GPG key ID (last 8 chars of fingerprint)
PAYCRAFT_SIGNING_KEY_ID=

# GPG key passphrase
PAYCRAFT_SIGNING_PASSWORD=

# Base64-encoded GPG private key block
# Generate: gpg --export-secret-keys --armor KEY_ID | base64
PAYCRAFT_GPG_KEY_CONTENTS=

# ── App Config ────────────────────────────────────────────────────────────────
# Payment provider: stripe or razorpay (filled by /paycraft-adopt-env)
PAYCRAFT_PROVIDER=

# Support email shown in the paywall
PAYCRAFT_SUPPORT_EMAIL=

# Default currency for new plans (iso code: inr, usd, eur, gbp)
PAYCRAFT_CURRENCY=inr

# Redirect URL after successful payment (your app's deep link or web URL)
# Used for BOTH test and live payment links (same scheme, different link mode)
PAYCRAFT_APP_REDIRECT_URL=

# ── Plan Definitions (filled by /paycraft-adopt-env) ─────────────────────────
# Number of subscription plans (e.g. 2 for monthly+yearly)
PAYCRAFT_PLAN_COUNT=
# Plan 1 (example: monthly)
PAYCRAFT_PLAN_1_ID=
PAYCRAFT_PLAN_1_NAME=
PAYCRAFT_PLAN_1_PRICE=
PAYCRAFT_PLAN_1_INTERVAL=
PAYCRAFT_PLAN_1_POPULAR=
# Plan 2 (example: yearly)
PAYCRAFT_PLAN_2_ID=
PAYCRAFT_PLAN_2_NAME=
PAYCRAFT_PLAN_2_PRICE=
PAYCRAFT_PLAN_2_INTERVAL=
PAYCRAFT_PLAN_2_POPULAR=
# Plan 3 (optional quarterly — leave blank if unused)
PAYCRAFT_PLAN_3_ID=
PAYCRAFT_PLAN_3_NAME=
PAYCRAFT_PLAN_3_PRICE=
PAYCRAFT_PLAN_3_INTERVAL=
PAYCRAFT_PLAN_3_POPULAR=
