# PayCraft Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# .env is gitignored — never commit real secrets.
# All keys are prefixed PAYCRAFT_ so Claude never confuses them with app keys.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL (e.g. https://abcdefghij.supabase.co)
# Find it: https://supabase.com/dashboard/project/<ref>/settings/api
PAYCRAFT_SUPABASE_URL=

# Project ref slug (the part after /project/ in your dashboard URL)
# Example: abcdefghij
PAYCRAFT_SUPABASE_PROJECT_REF=

# Anon/public key — safe to embed in client apps
# Find it: https://supabase.com/dashboard/project/<ref>/settings/api → Project API keys → anon
PAYCRAFT_SUPABASE_ANON_KEY=

# Service role key — NEVER expose in client apps; used only by Claude for setup
# Find it: https://supabase.com/dashboard/project/<ref>/settings/api → Project API keys → service_role
PAYCRAFT_SUPABASE_SERVICE_ROLE_KEY=

# Personal access token — used by Supabase CLI / Management API for migrations + deploy
# Generate at: https://supabase.com/dashboard/account/tokens
PAYCRAFT_SUPABASE_ACCESS_TOKEN=

# ── Stripe (if using StripeProvider) ─────────────────────────────────────────
# Secret key — used only by Claude to create products/prices/links via API
# Find it: https://dashboard.stripe.com/apikeys
# Use sk_test_... for testing, sk_live_... for production
PAYCRAFT_STRIPE_SECRET_KEY=

# Publishable key — embedded in client (optional, for display only)
# Find it: https://dashboard.stripe.com/apikeys → Publishable key
PAYCRAFT_STRIPE_PUBLISHABLE_KEY=

# Webhook signing secret — set AFTER creating the webhook endpoint in Stripe Dashboard
# Find it: https://dashboard.stripe.com/webhooks → your endpoint → Signing secret
PAYCRAFT_STRIPE_WEBHOOK_SECRET=

# Payment links — filled automatically by /setup-stripe or manually from Stripe Dashboard
PAYCRAFT_STRIPE_LINK_MONTHLY=
PAYCRAFT_STRIPE_LINK_QUARTERLY=
PAYCRAFT_STRIPE_LINK_YEARLY=

# Customer portal URL — enable at: https://dashboard.stripe.com/settings/billing/portal
PAYCRAFT_STRIPE_PORTAL_URL=

# ── Razorpay (if using RazorpayProvider) ─────────────────────────────────────
# Key ID — starts with rzp_test_ or rzp_live_
# Find it: https://dashboard.razorpay.com/app/keys
PAYCRAFT_RAZORPAY_KEY_ID=

# Key secret — treat like a password, never expose in client apps
PAYCRAFT_RAZORPAY_KEY_SECRET=

# Webhook secret — set when creating webhook in Razorpay Dashboard
# Find it: https://dashboard.razorpay.com/app/webhooks
PAYCRAFT_RAZORPAY_WEBHOOK_SECRET=

# Payment links — filled automatically by /setup-razorpay or manually
PAYCRAFT_RAZORPAY_LINK_MONTHLY=
PAYCRAFT_RAZORPAY_LINK_QUARTERLY=
PAYCRAFT_RAZORPAY_LINK_YEARLY=

# ── Maven Central (used by scripts/release.sh for local publishing) ───────────
# Username from https://central.sonatype.com/account
PAYCRAFT_MAVEN_CENTRAL_USERNAME=

# Password / token from Sonatype Central
PAYCRAFT_MAVEN_CENTRAL_PASSWORD=

# GPG key ID (last 8 chars of fingerprint)
PAYCRAFT_SIGNING_KEY_ID=

# GPG key passphrase
PAYCRAFT_SIGNING_PASSWORD=

# Base64-encoded GPG private key block
# Generate: gpg --export-secret-keys --armor KEY_ID | base64
PAYCRAFT_GPG_KEY_CONTENTS=

# ── App Config ────────────────────────────────────────────────────────────────
# Support email shown in the paywall
PAYCRAFT_SUPPORT_EMAIL=

# Default currency for new plans (iso code: inr, usd, eur, gbp)
PAYCRAFT_CURRENCY=inr

# Redirect URL after successful payment (your app's deep link or web URL)
PAYCRAFT_APP_REDIRECT_URL=
