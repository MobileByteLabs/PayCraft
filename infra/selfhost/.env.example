# PayCraft Self-Host Environment
# Copy to .env and fill in. Never commit .env.

# Postgres
PAYCRAFT_DB_PASSWORD=changeme-strong-password

# JWT — shared between db, auth, edge-runtime
# Generate: openssl rand -base64 32
PAYCRAFT_JWT_SECRET=

# Anon + service role keys — sign the JWT_SECRET above with role claims
# Use the generate-keys.sh script: ./generate-keys.sh
PAYCRAFT_ANON_KEY=
PAYCRAFT_SERVICE_ROLE_KEY=

# Token encryption key for Stripe Connect access tokens
# Generate: openssl rand -hex 32
PAYCRAFT_TOKEN_ENCRYPTION_KEY=

# OAuth state HMAC secret (used by Stripe Connect flow)
# Generate: openssl rand -hex 32
PAYCRAFT_OAUTH_STATE_SECRET=

# Stripe Connect platform credentials (your own — for billing your customers)
# Get from https://dashboard.stripe.com/settings/applications
PAYCRAFT_PLATFORM_STRIPE_SECRET_KEY=
PAYCRAFT_PLATFORM_STRIPE_CLIENT_ID=

# Public URLs (used in redirects + CORS)
PAYCRAFT_API_URL=http://localhost:54321
PAYCRAFT_DASHBOARD_URL=http://localhost:3000
